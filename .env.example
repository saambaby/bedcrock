# =============================================================================
# Bedcrock — Environment
# Copy this to .env and fill in. NEVER commit .env to git.
# =============================================================================

# --- Mode -------------------------------------------------------------------
# paper | live. Selects broker port and tags every record so paper and live
# data can live side-by-side in the same DB.
MODE=paper

# --- Database (Postgres) ----------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bedcrock
POSTGRES_USER=bedcrock
POSTGRES_PASSWORD=change_me_long_random_string
# Async DSN used by SQLAlchemy. Override only if running outside docker compose.
DATABASE_URL=postgresql+asyncpg://bedcrock:change_me_long_random_string@localhost:5432/bedcrock

# --- Broker (IBKR for both paper and live) ----------------------------------
# IB Gateway or TWS must be running. See docs/BROKER_SETUP.md.
# Paper: port 4002 (Gateway) or 7497 (TWS)
# Live:  port 4001 (Gateway) or 7496 (TWS)
# Mode↔port coupling is enforced at startup; mismatched config refuses to boot.
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=1
IBKR_ACCOUNT=

# --- Data Sources -----------------------------------------------------------
# Quiver Quantitative API. Get token at https://api.quiverquant.com/
QUIVER_API_KEY=

# Unusual Whales API. Get token at https://unusualwhales.com/pricing
UNUSUAL_WHALES_API_KEY=

# Finnhub. Free tier sufficient for earnings calendar. https://finnhub.io
FINNHUB_API_KEY=

# Polygon (OHLCV). Free tier works for end-of-day. https://polygon.io
# Leave blank to use yfinance fallback (slower, less reliable, but free).
POLYGON_API_KEY=

# SEC EDGAR requires a User-Agent string with contact info. No key.
# https://www.sec.gov/os/accessing-edgar-data
SEC_USER_AGENT=YourName-Bedcrock your.email@example.com

# --- Discord ---------------------------------------------------------------
# Four webhook URLs (one per channel) and one bot token.
# See docs/DISCORD_SETUP.md for step-by-step setup.
DISCORD_WEBHOOK_FIREHOSE=
DISCORD_WEBHOOK_HIGH_SCORE=
DISCORD_WEBHOOK_POSITIONS=
DISCORD_WEBHOOK_SYSTEM_HEALTH=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# --- API server -------------------------------------------------------------
# The /confirm, /skip, and /dashboard/* endpoints listen here.
# Discord bot calls /confirm and /skip; Claude Code Routines call /dashboard/*.
API_HOST=127.0.0.1
API_PORT=8080
# Used to sign /confirm deep links so they can't be forged.
API_SIGNING_SECRET=change_me_another_long_random_string
# Bearer token for /dashboard/* and /scoring-proposals endpoints. Used by
# Claude Code Routines. If unset, falls back to API_SIGNING_SECRET.
API_BEARER_TOKEN=

# --- Scheduling -------------------------------------------------------------
# All times in ET regardless of host TZ.
INGEST_INTERVAL_FAST_MIN=15        # Form 4 / news pollers
INGEST_INTERVAL_SLOW_MIN=30        # Politician / hedge fund pollers
INGEST_EARNINGS_HOUR_ET=6          # daily earnings calendar refresh (06:00 ET)

# --- Risk limits ------------------------------------------------------------
RISK_DAILY_LOSS_PCT=2.0
RISK_PER_TRADE_PCT=1.0
RISK_MAX_POSITION_SIZE_PCT=0.05    # half-Kelly cap (v2 N3); never more than 5% of equity in one position
RISK_SECTOR_CONCENTRATION_LIMIT=0.25  # max % of equity in any single sector ETF cluster (v2 N2)
RISK_MAX_OPEN_POSITIONS=8
RISK_MIN_ADV_USD=5000000           # paper. live = 20M
RISK_EARNINGS_BLACKOUT_DAYS=3
RISK_EVENT_BLACKOUT_DAYS=2

# --- Heavy-movement ingestor (v2 N1) ----------------------------------------
MOVEMENT_VOLUME_SPIKE_THRESHOLD=3.0
MOVEMENT_GAP_THRESHOLD=0.05
MOVEMENT_CHECK_INTERVAL_SECONDS=300

# --- Observability ----------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json                    # json | text
SENTRY_DSN=                        # optional

# =============================================================================
# Claude Code Routines — these vars are set in the ROUTINE config at
# claude.ai/code/routines, NOT in this .env. Listed here for reference only.
# =============================================================================
# API_BASE_URL=https://your-bedcrock-host.example.com
# API_BEARER_TOKEN=<same as server's API_BEARER_TOKEN>
# DISCORD_WEBHOOK_HIGH_SCORE=<same webhook URL as above>
# DISCORD_WEBHOOK_POSITIONS=<same webhook URL as above>
# DISCORD_WEBHOOK_SYSTEM_HEALTH=<same webhook URL as above>
